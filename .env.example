# ===== WhatsApp Cloud API (Meta) =====
# Token permanente del System User de Meta Business
WHATSAPP_TOKEN=pega_aqui_el_token
# Phone Number ID del número del bot (panel de Meta > WhatsApp > API Setup)
WHATSAPP_PHONE_NUMBER_ID=123456789012345
# Token de verificación del webhook (invéntalo tú, cualquier texto secreto)
WEBHOOK_VERIFY_TOKEN=un_secreto_que_tu_inventes

# ===== Números (formato internacional sin +, ej: 34612345678) =====
JALIL_PHONE=34XXXXXXXXX
ALE_PHONE=34XXXXXXXXX

# ===== Google Calendar (Service Account) =====
# Pega el JSON COMPLETO de la service account en una sola línea
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ===== Calendarios =====
CAL_ACTIVIDADES=xxxxx@group.calendar.google.com
CAL_MENTORIA=xxxxx@group.calendar.google.com
CAL_PERSONAL=xxxxx@group.calendar.google.com
CAL_VIAJES=xxxxx@group.calendar.google.com

# ===== Opcional: IA para comandos en lenguaje natural =====
# Si lo dejas vacío, el bot usa el formato simple "agrega: ..."
ANTHROPIC_API_KEY=

# Puerto (Render lo inyecta solo, no lo toques)
PORT=3000
